# Default: normalize text files to LF in the repo, auto-convert in working tree
* text=auto eol=lf

# Source code — always LF
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.json     text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.prisma   text eol=lf
*.sql      text eol=lf

# Shell scripts — must be LF
*.sh       text eol=lf

# Windows scripts — keep CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary files — never touch
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
